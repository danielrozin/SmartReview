generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// Auth (NextAuth.js compatible)
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ==========================================
// Users & Trust
// ==========================================

model User {
  id                   String    @id @default(cuid())
  email                String?   @unique
  emailVerified        DateTime?
  name                 String?
  username             String?   @unique
  displayName          String?
  avatar               String?
  bio                  String?   @default("")
  trustLevel           String    @default("newcomer")
  reputationScore      Int       @default(0)
  badges               String[]  @default([])
  expertiseCategories  String[]  @default([])
  verifiedProductCount Int       @default(0)
  joinedAt             DateTime  @default(now())
  lastActiveAt         DateTime  @default(now())

  accounts   Account[]
  sessions   Session[]
  reviews    Review[]
  threads    DiscussionThread[]
  comments   Comment[]
  votes      Vote[]
  reports    ModerationReport[] @relation("reporter")

  @@map("users")
}

// ==========================================
// Products & Categories
// ==========================================

model Category {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  description  String
  icon         String   @default("")
  image        String?
  productCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  products Product[]
  threads  DiscussionThread[]

  @@map("categories")
}

model Product {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  brand                String
  categoryId           String
  description          String   @db.Text
  image                String
  priceMin             Float
  priceMax             Float
  priceCurrency        String   @default("USD")
  smartScore           Int      @default(0)
  verifiedPurchaseRate Int      @default(0)
  reviewCount          Int      @default(0)
  rating5              Int      @default(0)
  rating4              Int      @default(0)
  rating3              Int      @default(0)
  rating2              Int      @default(0)
  rating1              Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  category        Category         @relation(fields: [categoryId], references: [id])
  aiSummary       AISummary?
  specs           ProductSpec[]
  recurringIssues RecurringIssue[]
  comparisons     ComparisonRef[]
  faqs            FAQ[]
  reviews         Review[]
  youtubeVideos   YouTubeVideo[]
  threads         DiscussionThread[]

  @@index([categoryId])
  @@index([smartScore(sort: Desc)])
  @@index([brand])
  @@map("products")
}

model AISummary {
  id             String   @id @default(cuid())
  productId      String   @unique
  whatPeopleLove String[]
  whatPeopleHate String[]
  bestFor        String[]
  notFor         String[]
  topComplaints  String[]
  keyFacts       String[]

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("ai_summaries")
}

model ProductSpec {
  id        String  @id @default(cuid())
  productId String
  label     String
  value     String
  group     String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_specs")
}

model RecurringIssue {
  id           String @id @default(cuid())
  productId    String
  title        String
  mentionCount Int    @default(0)
  severity     String
  description  String @db.Text

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("recurring_issues")
}

model ComparisonRef {
  id                String  @id @default(cuid())
  productId         String
  targetProductId   String?
  targetProductName String
  targetProductSlug String
  searchVolume      Int?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("comparison_refs")
}

model FAQ {
  id        String @id @default(cuid())
  productId String
  question  String @db.Text
  answer    String @db.Text

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("faqs")
}

model YouTubeVideo {
  id        String @id @default(cuid())
  productId String
  videoId   String
  title     String

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("youtube_videos")
}

// ==========================================
// Reviews
// ==========================================

model Review {
  id               String   @id @default(cuid())
  productId        String
  userId           String?
  headline         String
  rating           Int
  verifiedPurchase Boolean  @default(false)
  verificationTier String   @default("unverified")
  timeOwned        String?
  experienceLevel  String   @default("beginner")
  pros             String[]
  cons             String[]
  reliabilityRating Float?
  easeOfUseRating  Float?
  valueRating      Float?
  body             String   @db.Text
  aiTopics         String[] @default([])
  authorName       String
  authorAvatar     String?
  helpfulCount     Int      @default(0)
  status           String   @default("published")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  votes   Vote[]

  @@index([productId])
  @@index([userId])
  @@index([status])
  @@index([rating])
  @@map("reviews")
}

// ==========================================
// Community: Discussions & Comments
// ==========================================

model DiscussionThread {
  id             String   @id @default(cuid())
  title          String
  body           String   @db.Text
  threadType     String   @default("discussion")
  authorId       String
  productId      String?
  categoryId     String?
  upvotes        Int      @default(0)
  downvotes      Int      @default(0)
  commentCount   Int      @default(0)
  viewCount      Int      @default(0)
  isPinned       Boolean  @default(false)
  isResolved     Boolean  @default(false)
  tags           String[] @default([])
  createdAt      DateTime @default(now())
  lastActivityAt DateTime @default(now())

  author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  comments Comment[]
  votes    Vote[]

  @@index([authorId])
  @@index([productId])
  @@index([categoryId])
  @@index([threadType])
  @@index([lastActivityAt(sort: Desc)])
  @@map("discussion_threads")
}

model Comment {
  id              String   @id @default(cuid())
  threadId        String
  parentId        String?
  authorId        String
  body            String   @db.Text
  upvotes         Int      @default(0)
  downvotes       Int      @default(0)
  isTopAnswer     Boolean  @default(false)
  isOwnerVerified Boolean  @default(false)
  helpfulCount    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  thread  DiscussionThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parent  Comment?         @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[]        @relation("CommentReplies")
  author  User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes   Vote[]

  @@index([threadId])
  @@index([parentId])
  @@index([authorId])
  @@map("comments")
}

// ==========================================
// Votes (polymorphic)
// ==========================================

model Vote {
  id        String   @id @default(cuid())
  userId    String
  voteType  String
  reviewId  String?
  threadId  String?
  commentId String?
  createdAt DateTime @default(now())

  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  review  Review?           @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  thread  DiscussionThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  comment Comment?          @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId, voteType])
  @@unique([userId, threadId, voteType])
  @@unique([userId, commentId, voteType])
  @@index([userId])
  @@map("votes")
}

// ==========================================
// Moderation
// ==========================================

model ModerationReport {
  id          String   @id @default(cuid())
  contentType String
  contentId   String
  reporterId  String
  reason      String
  details     String?  @db.Text
  status      String   @default("pending")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  reporter User @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([contentType, contentId])
  @@index([status])
  @@map("moderation_reports")
}
