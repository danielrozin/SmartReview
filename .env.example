# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/smartreview?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth Providers (optional — enables social login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# DataForSEO API (optional — needed for /api/seo/insights)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=SmartReview
